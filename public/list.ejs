<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("partials/head.ejs") %>
</head>

<body>

  <%- include("partials/header.ejs") %>

  <main class="container-fluid px-4 py-4">
    <div class="mb-4">
      <h1 class="gfn-title">GeForce NOW Games</h1>
      <p class="gfn-subtitle">Complete list of games available on GeForce NOW. <span id="gameCount" class="badge badge-gfn"></span></p>
    </div>

    <table id="gameslist" class="table table-bordered display responsive" style="width:100%">
      <thead>
        <tr>
          <th style="width:70%">Title</th>
          <th style="width:30%">Store / Launcher</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </main>

  <script type="text/javascript">
    $(document).ready(function() {
      var table = $('#gameslist').DataTable({
        "ajax": {
          "url": "data/data.json",
          "dataSrc": "data"
        },
        "responsive": true,
        "searching": true,
        "pageLength": 50,
        "order": [[0, "asc"]],
        "columns": [
          { "data": "title" },
          { "data": "store" }
        ],
        "language": {
          "search": '<i class="fas fa-search"></i>',
          "searchPlaceholder": "Search games...",
          "lengthMenu": "Show _MENU_ games",
          "info": "Showing _START_ to _END_ of _TOTAL_ games",
          "infoFiltered": "(filtered from _MAX_ total games)"
        },
        "initComplete": function() {
          var total = this.api().data().length;
          $('#gameCount').text(total.toLocaleString() + ' games');
        }
      });
    });
  </script>

  <%- include("partials/analytics.ejs") %>

</body>

</html>
